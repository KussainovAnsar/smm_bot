TELEGRAM_BOT_TOKEN=replace_me

# Recommended free/prototype providers for this MVP: gemini or groq.
AI_PROVIDER=gemini
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite

GROQ_API_KEY=replace_me
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TRANSCRIBE_MODEL=whisper-large-v3

# Optional OpenAI fallback.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_IMAGE_MODEL=gpt-image-1.5

DATABASE_PATH=work/smm_bot.sqlite3
TEMP_DIR=work/tmp

# Set to true when you want the bot to generate and send an AI image.
# When false, the bot returns an image prompt and uses uploaded-photo analysis.
OPENAI_ENABLE_IMAGE_GENERATION=false
