TELEGRAM_BOT_TOKEN=replace_me
OPENAI_API_KEY=replace_me

# Defaults match current OpenAI docs patterns as of 2026.
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_IMAGE_MODEL=gpt-image-1.5

DATABASE_PATH=work/smm_bot.sqlite3
TEMP_DIR=work/tmp

# Set to true when you want the bot to generate and send an AI image.
# When false, the bot returns an image prompt and uses uploaded-photo analysis.
OPENAI_ENABLE_IMAGE_GENERATION=false
